# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# IMPORTANT: PostgreSQL is REQUIRED for multi-tenancy. SQLite will NOT work.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.dialeasy.easyian.com,api.dialeasy.easyian.com

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DB_NAME=telecrm_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set CORS_ALLOW_ALL_ORIGINS=True only in development.
# In production, list exact origins (Flutter app, web app).
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:8000,https://demo.dialeasy.easyian.com

# ── JWT Configuration (SimpleJWT) ─────────────────────────────────────────────
# Use a DIFFERENT key from SECRET_KEY for extra isolation (recommended)
JWT_SECRET_KEY=your-jwt-signing-secret-key-here
# Access token lifetime in minutes (default: 15)
JWT_ACCESS_MINUTES=15
# Refresh token lifetime in days (default: 7)
JWT_REFRESH_DAYS=7

# ── Central API Domain ────────────────────────────────────────────────────────
# The single HTTPS domain for mobile/Flutter API access.
# No wildcard SSL required — just a standard cert for this one subdomain.
CENTRAL_API_DOMAIN=api.dialeasy.easyian.com

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── FCM Push Notifications ────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Media / Storage ──────────────────────────────────────────────────────────
# For production, switch to S3/GCS
MEDIA_URL=/media/
