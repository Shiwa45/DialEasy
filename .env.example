# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# IMPORTANT: PostgreSQL is REQUIRED for multi-tenancy. SQLite will NOT work.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.telecrm.com

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Install PostgreSQL locally or use a managed service (Supabase, Neon, Railway)
DB_NAME=telecrm_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ── CORS (add your Flutter dev IP) ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:8000

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# (stored per-tenant in IntegrationConfig, but fallback env vars useful for dev)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Media / Storage ──────────────────────────────────────────────────────────
# For production, switch to S3/GCS
MEDIA_URL=/media/
